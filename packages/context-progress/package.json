{
  "name": "@oh-my-sidebar/opencode-context-progress",
  "version": "1.0.0",
  "description": "OpenCode TUI sidebar plugin for context usage progress",
  "repository": {
    "type": "git",
    "url": "https://github.com/edso404/oh-my-sidebar",
    "directory": "packages/context-progress"
  },
  "homepage": "https://github.com/edso404/oh-my-sidebar/tree/main/packages/context-progress",
  "bugs": {
    "url": "https://github.com/edso404/oh-my-sidebar/issues"
  },
  "type": "module",
  "exports": {
    "./tui": {
      "import": "./dist/tui.js"
    }
  },
  "files": [
