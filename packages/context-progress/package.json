  },
  "peerDependencies": {
    "@opencode-ai/plugin": "catalog:",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "solid-js": "catalog:"
  },
  "devDependencies": {
    "@oh-my-sidebar/opencode-shared": "workspace:*",
    "@opencode-ai/plugin": "catalog:",
    "@opencode-ai/sdk": "catalog:",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "solid-js": "catalog:"
  }
}
